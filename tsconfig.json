{
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "src/*": ["./src/*"],
      "app/*": ["./app/*"],
      "public/*": ["./public/*"]
    },
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": ["node"],
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "tailwind.config.ts",
    ".next/dev/types/**/*.ts",
    "src/styles/**/*.d.ts"
  ],
  "exclude": ["node_modules", "out", "dist"]
}
